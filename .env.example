#EXPO_PUBLIC_API_GATEWAY_URL=https://your-api-gateway.execute-api.us-east-1.amazonaws.com
EXPO_PUBLIC_API_GATEWAY_URL=http://localhost:8001
# Google OAuth — crear en console.cloud.google.com > APIs & Services > Credentials
# El webClientId (tipo "Web application") es obligatorio.
# Para Expo Go alcanza con el webClientId como fallback en iOS/Android.
# En producción (bare workflow) conviene crear clients nativos separados.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_ios_client_id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_ORDERS_API_URL=http://localhost:8003