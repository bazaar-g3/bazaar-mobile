{
  "expo": {
    "name": "Bazaar",
    "slug": "bazaar-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bazaar",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "package": "com.bazaar.app",
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.bazaar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "networkSecurityConfig": "./network-security-config.xml"
          }
        }
      ]
    ],
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "88c89600-1f5e-4dde-b560-e3f24fc54a4e"
      }
    }
  }
}
